{
  "NetworkManager": {
    "openrc":  { "package": "networkmanager-openrc",  "enable": "rc-update add NetworkManager default" },
    "runit":   { "package": "networkmanager-runit",   "enable": "ln -s /etc/runit/sv/NetworkManager /etc/runit/runsvdir/default/" },
    "s6":      { "package": "networkmanager-s6",      "enable": "s6-rc-bundle-update add default NetworkManager" },
    "dinit":   { "package": "networkmanager-dinit",    "enable": "dinitctl enable NetworkManager" }
  },
